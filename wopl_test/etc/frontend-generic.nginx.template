#
# To be used in the `server` section of nginx.
#

root                $WOPL_TEST_HOME/project/frontend/dist;
access_log          $WOPL_TEST_HOME/logs/frontend-access.log;
error_log           $WOPL_TEST_HOME/logs/frontend-error.log;

# Entry point.
index               index.html;

# Add compression.
gzip                on;
gzip_vary           on;
gzip_min_length     1024;
gzip_types          text/plain text/css text/xml text/javascript application/x-javascript application/xml+rss application/json application/javascript;

# Security headers
add_header X-Frame-Options "SAMEORIGIN" always;
add_header X-Content-Type-Options "nosniff" always;
add_header X-XSS-Protection "1; mode=block" always;

location ^~ /assets/ {
    # Serve uploads from alias and set long-term caching only if uploads are
    # immutable (or use hashed filenames). Otherwise reduce cache lifetime.
    add_header Cache-Control "public, max-age=31536000, immutable";
    expires 1y;
    access_log off;
    try_files $uri =404;
}

location ^~ /uploads/ {
    # Serve uploads from alias and set long-term caching only if uploads are
    # immutable (or use hashed filenames). Otherwise reduce cache lifetime.
    alias $WOPL_TEST_HOME/uploads/;
    add_header Cache-Control "public, max-age=31536000, immutable";
    expires 1y;
    access_log off;
    try_files $uri =404;
}

location ^~ /public/ {
    alias $WOPL_TEST_HOME/project/frontend/public/;
    # Keep public assets in /public cacheable but only for 1 day to allow
    # reasonably quick updates for non-fingerprinted files.
    add_header Cache-Control "public, max-age=86400";
    expires 1d;
    access_log off;
    try_files $uri =404;
}

location / {
    # SPA fallback — keep index.html un-cached so new deployments are visible
    add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
    add_header Pragma "no-cache" always;
    expires off;
    try_files $uri $uri/ /index.html;
}
